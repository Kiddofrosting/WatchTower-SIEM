# ============================================================
# WatchTower SIEM - Environment Configuration
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ============================================================

# Flask
FLASK_ENV=production
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_SECRET_KEY=CHANGE_ME_TO_ANOTHER_RANDOM_64_CHAR_STRING
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=604800

# MongoDB
# Docker Compose uses the service name "mongodb" as host
MONGO_URI=mongodb://watchtower_user:watchtowerpass@mongodb:27017/watchtower?authSource=watchtower
MONGO_ROOT_PASSWORD=CHANGE_ME_MONGO_ROOT_PASSWORD

# Redis / Celery
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/1

# Email (SMTP) - optional but recommended
MAIL_SERVER=smtp.yourdomain.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=watchtower@yourdomain.com
MAIL_PASSWORD=CHANGE_ME_SMTP_PASSWORD
MAIL_DEFAULT_SENDER=WatchTower SIEM <watchtower@yourdomain.com>

# Slack - optional
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME

# AI / LLM - optional but enables AI remediation
ANTHROPIC_API_KEY=CHANGE_ME_ANTHROPIC_KEY
OPENAI_API_KEY=CHANGE_ME_OPENAI_KEY
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6

# Security
BCRYPT_LOG_ROUNDS=13
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict
WTF_CSRF_TIME_LIMIT=3600

# Rate Limiting
RATELIMIT_DEFAULT=200 per hour
RATELIMIT_INGEST=1000 per minute
RATELIMIT_LOGIN=10 per minute

# Data Retention (days)
RETENTION_RAW_EVENTS=90
RETENTION_INCIDENTS=365
RETENTION_AUDIT_LOG=730
RETENTION_NORMALIZED_EVENTS=180

# GeoIP (MaxMind GeoLite2 DB path) - optional
GEOIP_DB_PATH=/opt/watchtower/GeoLite2-City.mmdb

# Sentry (optional - error tracking)
SENTRY_DSN=

# Application
APP_HOST=0.0.0.0
APP_PORT=5000
BASE_URL=http://localhost:5000
SUPER_ADMIN_EMAIL=admin@watchtower.local
SUPER_ADMIN_PASSWORD=Admin@WatchTower1!

# Organization
ORG_NAME=Your Organization
ORG_CONTACT_EMAIL=security@yourdomain.com

# Flower (Celery task monitoring)
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_FLOWER_PASSWORD
